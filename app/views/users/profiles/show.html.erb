<% content_for(:title, t('.head_title')) %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
      <h1 class="text-center mb-4 fw-bold"><%= t('.title') %></h1>

      <div class="shadow-sm p-4 border rounded bg-white">

        <%# ユーザー情報セクション %>
        <div class="mb-3">
          <p class="form-label fw-semibold mb-1"><%= t('.name') %></p>
          <p class="ms-1"><%= @user.name %></p>
        </div>

        <div class="mb-3">
          <p class="form-label fw-semibold mb-1"><%= t('.email') %></p>
          <p class="ms-1"><%= @user.email %></p>
        </div>

        <%# ダイスコレクションセクション %>
        <div class="border-top pt-4 mt-4">
          <%= turbo_frame_tag "dice_collection_grid" do %>
          <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="form-label fw-semibold mb-0"><%= t('.dice_collection') %></p>
            <div class="d-flex align-items-center gap-2">
              <span class="text-muted small">
                <%= t('.collection_count', count: @user.dice_unlocks.count, total: User::COLLECTABLE_DICE_KEYS.size) %>
              </span>
              <button class="btn btn-outline-secondary btn-sm"
                      data-bs-toggle="modal"
                      data-bs-target="#rewardHelpModal">
                ?
              </button>
            </div>
          </div>

          <%= form_with model: @user, url: profile_path, method: :patch,
                        data: { controller: "dice-collection", turbo_frame: "_top" } do |f| %> <%# turbo_frame: "_top"を設定し、フォームを送信した場合のみ通常通りの画面更新を行う %>

            <%# 現在のアイコンプレビュー %>
            <div class="text-center mb-4">
              <% if @user.site_icon == "none" %>
                <%= image_tag 'all_dice/logo_defaults.webp',
                              width: 120, height: 120,
                              class: 'rounded border d-none',
                              data: { dice_collection_target: "preview" },
                              alt: t('.dice_collection') %>
                <p class="text-muted small mt-2"
                   data-dice-collection-target="label"><%= t('.dice_hidden') %></p>
              <% else %>
                <%= image_tag @user.site_icon_path,
                              width: 120, height: 120,
                              class: 'rounded border',
                              data: { dice_collection_target: "preview" },
                              alt: t('.dice_collection') %>
                <p class="text-muted small mt-2 d-none"
                   data-dice-collection-target="label"></p>
              <% end %>
            </div>

            <%# hidden field で選択値を保持 %>
            <%= f.hidden_field :site_icon, data: { dice_collection_target: "input" } %>

            <%# 特殊アイコン（常時選択可能） %>
            <div class="mb-3">
              <p class="small fw-semibold text-muted mb-2"><%= t('.special_icons_label') %></p>
              <div class="d-flex gap-2">
                <div class="dice-item <%= 'selected' if @user.site_icon == 'defaults' %>"
                     data-action="click->dice-collection#select"
                     data-dice-collection-key-param="defaults"
                     title="<%= t('.dice_default') %>">
                  <%= image_tag 'all_dice/logo_defaults.webp', width: 60, height: 60,
                                class: 'rounded border', alt: t('.dice_default') %>
                  <p class="small text-center mt-1 mb-0" style="font-size: 10px;"><%= t('.dice_default_short') %></p>
                </div>
                <div class="dice-item <%= 'selected' if @user.site_icon == 'none' %>"
                     data-action="click->dice-collection#select"
                     data-dice-collection-key-param="none"
                     title="<%= t('.dice_hidden') %>">
                  <div class="rounded border d-flex align-items-center justify-content-center bg-light"
                       style="width: 60px; height: 60px;">
                    <span class="text-muted" style="font-size: 20px;">×</span>
                  </div>
                  <p class="small text-center mt-1 mb-0" style="font-size: 10px;"><%= t('.dice_hidden_short') %></p>
                </div>
              </div>
            </div>

            <%# ダイスコレクション（グリッド表示） %>
            <div class="mb-3">
              <p class="small fw-semibold text-muted mb-2"><%= t('.collection_label') %></p>
              <div class="row row-cols-4 row-cols-sm-6 row-cols-md-8 g-2">
                <% User::COLLECTABLE_DICE_KEYS.each do |key| %>
                  <% unlocked = @user.dice_unlocked?(key) %>
                  <div class="col">
                    <div class="dice-item text-center <%= 'selected' if @user.site_icon == key %> <%= 'locked' unless unlocked %>"
                         <% if unlocked %>
                           data-action="click->dice-collection#select"
                           data-dice-collection-key-param="<%= key %>"
                         <% end %>
                         title="<%= unlocked ? User::DICE_DISPLAY_NAMES[key] : t('.locked_dice') %>">
                      <div class="position-relative d-inline-block">
                        <%= image_tag "all_dice/#{key}.webp",
                                      width: 50, height: 50,
                                      class: "rounded border #{'dice-locked' unless unlocked}",
                                      alt: User::DICE_DISPLAY_NAMES[key] || key %>
                        <% unless unlocked %>
                          <div class="position-absolute top-50 start-50 translate-middle">
                            <span style="font-size: 16px;">🔒</span>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>

            <%= f.submit t('.save_dice'), class: 'btn btn-primary mt-3 w-100' %>

          <% end %>
          <% end %><%# /turbo_frame dice_collection_grid %>
        </div>

      </div>

      <div class="d-flex justify-content-center gap-3 mt-4">
        <%= link_to t('defaults.back_top'), root_path, class: 'btn btn-outline-secondary btn-lg px-4' %>
        <%= link_to t('.edit_account'), edit_user_registration_path, class: 'btn btn-primary btn-lg shadow-sm' %>
      </div>
    </div>
  </div>
</div>

<%# コンプリートポップアップ（Turbo Streamで挿入される） %>
<div id="completion-popup-container"></div>
