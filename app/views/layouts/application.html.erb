<!DOCTYPE html>
<html>
  <head>
    <title><%= page_title(yield(:title)) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# OGP meta tags %>
    <meta property="og:title" content="<%= t('ogp.title') %>">
    <meta property="og:description" content="<%= t('ogp.description') %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= root_url %>">
    <meta property="og:image" content="<%= ogp_image_url %>">
    <meta property="og:site_name" content="<%= t('ogp.site_name') %>">
    <meta property="og:locale" content="<%= I18n.locale.to_s.tr('-', '_') %>">
    <meta name="description" content="<%= t('ogp.description') %>">
    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= t('ogp.title') %>">
    <meta name="twitter:description" content="<%= t('ogp.description') %>">
    <meta name="twitter:image" content="<%= ogp_image_url %>">

    <%= yield :head %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <% if user_signed_in? && current_user.tutorial_active? %>
      <meta name="tutorial-step" content="<%= current_user.tutorial_step %>">
    <% end %>
    <% if user_signed_in? && current_user.collection_tutorial_active? %>
      <meta name="collection-tutorial-step" content="<%= current_user.collection_tutorial_step %>">
    <% end %>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-JSL1E6TT3F"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-JSL1E6TT3F');
    </script>
  </head>

  <body data-controller="tutorial loading collection-tutorial"
        data-tutorial-i18n-value="<%= t('tutorial').to_json %>"
        data-collection-tutorial-i18n-value="<%= t('collection_tutorial').to_json %>">
    <%# ローディングオーバーレイ（z-index: 9000 でチュートリアル Shepherd より下） %>
    <div class="loading-overlay" data-loading-target="overlay">
      <div class="spinner-border text-light" role="status" style="width: 3rem; height: 3rem;">
        <span class="visually-hidden">Loading...</span>
      </div>
    </div>

    <%= render 'shared/header' %>
    <%= render 'shared/flash_message'%>
    <body class="bg-body-tertiary">
    <%= yield %>
    <%= render 'shared/footer' %>
  </body>
</html>
