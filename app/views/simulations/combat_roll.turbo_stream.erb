<%# ボタンエリアを先に更新（dice_result は dice_roll_area 内にあるため） 1回目以降は「もう一度シミュレーション」テキストに変更する %>
<%= turbo_stream.update "dice_roll_area" do %>
  <div class="container">
    <div class="d-flex justify-content-center mt-5 mb-5">
      <%= button_to t('simulations.start_simulation.retry'),
            combat_roll_path,
            method: :post,
            class: 'btn btn-success btn-lg px-5 shadow fw-bold simulation-button',
            data: { turbo_stream: true, simulation_result_target: "button" } %>
    </div>

    <div id="dice_result" class="result-area mt-4">
    </div>
  </div>
<% end %>

<%= turbo_stream.update "dice_result" do %>
  <%# @decision[:side] = :ally(味方勝利) / :enemy(敵勝利) / :draw %>
  <% side    = @decision[:side] %>
  <% is_draw = side == :draw %>

  <% if is_draw %>
    <%# 引き分け: 双方を敗者扱い、左=敵・右=味方の固定レイアウトを維持 %>
    <% enemy_char      = @decision[:loser] %>
    <% ally_char       = @decision[:winner] %>
    <% enemy_is_loser  = true %>
    <% ally_is_loser   = true %>
  <% elsif side == :ally %>
    <%# 味方勝利: 敵が敗者 %>
    <% ally_char      = @decision[:winner] %>
    <% enemy_char     = @decision[:loser] %>
    <% ally_is_loser  = false %>
    <% enemy_is_loser = true %>
  <% else %>
    <%# 敵勝利: 味方が敗者 %>
    <% enemy_char     = @decision[:winner] %>
    <% ally_char      = @decision[:loser] %>
    <% enemy_is_loser = false %>
    <% ally_is_loser  = true %>
  <% end %>

  <%# ----- ヘッダーカラーの決定 ----- %>
  <% theme_color = case side
                  when :ally  then 'primary'
                  when :enemy then 'danger'
                  when :draw  then 'secondary'
                  end %>

  <div data-controller="simulation-result">
    <%# ----- ① 勝敗ヘッダーカード ----- %>
    <div class="card shadow mb-4 border-<%= theme_color %> fade-in-ready result-header"
         data-simulation-result-target="section">
      <div class="card-header bg-<%= theme_color %> text-white text-center fw-bold fs-5">
        <i class="bi bi-flag-fill me-2"></i>
        <% if is_draw %>
          <%= t('.draw') %>
        <% else %>
          <%= @decision[:winner].name %><%= t('.victory') %>
        <% end %>
        <%= t(".finish_turn_suffix", finish_turn: @finish_turn) %>
      </div>
    </div>

    <%# ----- ② キャラクター結果カード（敵:左 / 味方:右 で固定） ----- %>
    <div class="row g-3 mb-4 result-card-container fade-in-ready"
         data-simulation-result-target="section">
      <%# === 敵カード（左） === %>
      <div class="col-md-6">
        <div class="card border-danger h-100 shadow-sm <%= enemy_is_loser ? "result-loser #{"result-draw" if is_draw}" : "" %>">
          <div class="card-body p-3 text-center">
            <% unless is_draw %>
              <div class="badge <%= enemy_is_loser ? "bg-danger" : "bg-success" %> mb-2 px-3 text-uppercase">
                <%= enemy_is_loser ? t('.loser') : t('.winner') %>
              </div>
            <% end %>
            <div class="d-flex align-items-center justify-content-center gap-3">
              <% if enemy_char.icon.attached? %>
                <%= image_tag enemy_char.icon.variant(resize_to_fill: [80, 80]),
                  class: "rounded-circle border border-danger border-2 object-fit-cover flex-shrink-0",
                  style: "width: 80px; height: 80px;",
                  alt: enemy_char.name %>
              <% else %>
                <%= image_tag "tentative_character_icon.png",
                  class: "rounded-circle border border-danger border-2 object-fit-cover flex-shrink-0",
                  style: "width: 80px; height: 80px;",
                  alt: "アイコン" %>
              <% end %>
              <div>
                <h4 class="card-title fw-bold text-danger mb-1"><%= enemy_char.name %></h4>
                <p class="card-text mb-0 fs-5 fw-semibold">
                  <small class="text-secondary fs-6"><%= t('.final_hp') %></small> <%= enemy_char.current_hp %>
                  <% if enemy_is_loser && @determination.to_s != "healthy" %>
                    <span class="badge status-badge status-badge--<%= @determination %> ms-2 position-relative" style="z-index: 2;">
                      <%= t(".#{@determination}") %>
                    </span>
                  <% end %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# === 味方カード（右） === %>
      <div class="col-md-6">
        <div class="card border-primary h-100 shadow-sm <%= ally_is_loser ? "result-loser #{"result-draw" if is_draw}" : "" %>">
          <div class="card-body p-3 text-center">
            <% unless is_draw %>
              <div class="badge <%= ally_is_loser ? "bg-danger" : "bg-success" %> mb-2 px-3 text-uppercase">
                <%= ally_is_loser ? t('.loser') : t('.winner') %>
              </div>
            <% end %>
            <div class="d-flex align-items-center justify-content-center gap-3">
              <% if ally_char.icon.attached? %>
                <%= image_tag ally_char.icon.variant(resize_to_fill: [80, 80]),
                  class: "rounded-circle border border-primary border-2 object-fit-cover flex-shrink-0",
                  style: "width: 80px; height: 80px;",
                  alt: ally_char.name %>
              <% else %>
                <%= image_tag "tentative_character_icon.png",
                  class: "rounded-circle border border-primary border-2 object-fit-cover flex-shrink-0",
                  style: "width: 80px; height: 80px;",
                  alt: "アイコン" %>
              <% end %>
              <div>
                <h4 class="card-title fw-bold text-primary mb-1"><%= ally_char.name %></h4>
                <p class="card-text mb-0 fs-5 fw-semibold">
                  <small class="text-secondary fs-6"><%= t('.final_hp') %></small> <%= ally_char.current_hp %>
                  <% if ally_is_loser && @determination.to_s != "healthy" %>
                    <span class="badge status-badge status-badge--<%= @determination %> ms-2 position-relative" style="z-index: 2;">
                      <%= t(".#{@determination}") %>
                    </span>
                  <% end %>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ----- ③ ターン詳細アコーディオン ----- %>
    <div class="accordion shadow-sm mb-4 fade-in-ready"
         id="simulationMainAccordion"
         data-simulation-result-target="section">
      <div class="accordion-item border-secondary">
        <h2 class="accordion-header">
          <button class="accordion-button fw-bold bg-secondary text-white" type="button"
                  data-bs-toggle="collapse" data-bs-target="#collapseMain"
                  aria-expanded="true" aria-controls="collapseMain">
            <%= t('.title') %>
          </button>
        </h2>

        <div id="collapseMain" class="accordion-collapse collapse show" data-bs-parent="#simulationMainAccordion">
          <div class="accordion-body bg-light-subtle p-3">
            <div class="accordion accordion-flush" id="turnAccordionGroup">
              <% @sorted_results.group_by { |r| r[:turn] }.each do |turn, results| %>
                <div class="accordion-item mb-2 border rounded overflow-hidden shadow-sm">
                  <h2 class="accordion-header">
                    <button class="accordion-button collapsed py-2 fw-bold" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapseTurn<%= turn %>"
                            aria-expanded="false" aria-controls="collapseTurn<%= turn %>">
                      <%= turn %> <%= t('.turn') %>
                    </button>
                  </h2>

                  <div id="collapseTurn<%= turn %>" class="accordion-collapse collapse" data-bs-parent="#turnAccordionGroup">
                    <div class="accordion-body bg-white">
                      <div class="row row-cols-1 g-3">
                        <% results.each do |result| %>
                          <div class="col">
                            <% is_ally = result[:side] == :ally %>
                            <% attacker_char = is_ally ? ally_char : enemy_char %>
                            <div class="alert <%= is_ally ? 'alert-success' : 'alert-danger' %> border-start border-4 mb-0 shadow-sm d-flex align-items-start gap-3">
                              <% if attacker_char.icon.attached? %>
                                <%= image_tag attacker_char.icon.variant(resize_to_fill: [70, 70]),
                                  class: "rounded-circle object-fit-cover flex-shrink-0",
                                  style: "width: 70px; height: 70px;",
                                  alt: attacker_char.name %>
                              <% else %>
                                <%= image_tag "tentative_character_icon.png",
                                  class: "rounded-circle object-fit-cover flex-shrink-0",
                                  style: "width: 70px; height: 70px;",
                                  alt: "アイコン" %>
                              <% end %>
                              <div>
                                <h5 class="fw-bold h6 mb-1"><%= result[:attacker_name] %><%= t('.to_attack') %></h5>
                                <p class="mb-1 small">【<%= t(".status.#{result[:status]}") %>】</p>
                                <small class="d-block text-body-secondary">
                                  <%= t(".messages.#{result[:status]}_html",
                                          attacker: result[:attacker_name],
                                          defender: result[:defender_name],
                                          attack_text: result[:attack_text],
                                          evasion_text: result[:evasion_text],
                                          damage_text: result[:damage_text],
                                          remaining_hp: result[:remaining_hp],
                                          armor: result[:armor],
                                          final_damage: result[:final_damage],
                                        ) %>
                                </small>
                              </div>
                            </div>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div><%# / data-controller="simulation-result" %>
<% end %>
