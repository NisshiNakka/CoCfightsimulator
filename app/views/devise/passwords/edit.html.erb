<% content_for(:title) { t('.change_your_password') } %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
      <h1 class="text-center mb-4 fw-bold"><%= t('.change_your_password') %></h1>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "shadow-sm p-4 border rounded bg-white" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="mb-3">
          <%= f.label :password, t('.new_password'), class: "form-label fw-semibold" %>
          <% if @minimum_password_length %>
            <span class="text-muted small ms-1"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></span>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="mb-4">
          <%= f.label :password_confirmation, t('.confirm_new_password'), class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="d-grid">
          <%= f.submit t('.change_my_password'), class: "btn btn-primary btn-lg shadow-sm" %>
        </div>
      <% end %>

      <div class="text-center mt-3">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
