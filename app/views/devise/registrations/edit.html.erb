<% content_for(:title, t('.head_title')) %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <h1 class="text-center mb-4 fw-bold"><%= t('.title', resource: devise_i18n_fix_model_name_case(resource.model_name.human, i18n_key: 'registrations.edit.title')) %></h1>

      <%= form_with model: @user, scope: @user, url: user_registration_path, method: :put, class: "shadow-sm p-4 border rounded bg-white" do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="mb-3">
          <%= f.label :name, class: "form-label fw-semibold" %>
          <%= f.text_field :name, autocomplete: "name", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :email, class: "form-label fw-semibold" %>
          <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
          <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
            <div class="form-text text-warning"><%= t('.currently_waiting_confirmation_for_email', email: resource.unconfirmed_email) %></div>
          <% end %>
        </div>

        <div class="mb-3">
          <%= f.label :password, class: "form-label fw-semibold" %>
          <span class="text-muted small ms-1"><%= t('.leave_blank_if_you_don_t_want_to_change_it') %></span>
          <% if @minimum_password_length %>
            <span class="text-muted small ms-1"><%= t('devise.shared.minimum_password_length', count: @minimum_password_length) %></span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, class: "form-label fw-semibold" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
        </div>

        <% unless resource.provider.present? %>
          <div class="mb-4">
            <%= f.label :current_password, class: "form-label fw-semibold" %>
            <span class="text-muted small ms-1"><%= t('.we_need_your_current_password_to_confirm_your_changes') %></span>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control" %>
          </div>
        <% end %>

        <div class="d-grid">
          <%= f.submit t('.update'), class: "btn btn-primary btn-lg shadow-sm" %>
        </div>
      <% end %>

      <div class="mt-4 p-3 border rounded bg-white shadow-sm">
        <h2 class="h5 fw-bold text-danger mb-2"><%= t('.cancel_my_account') %></h2>
        <p class="text-muted small mb-3"><%= t('.unhappy') %></p>
        <%= button_to t('.cancel_my_account'), registration_path(resource_name),
            data: { confirm: t('.are_you_sure'), turbo_confirm: t('.are_you_sure') },
            method: :delete,
            class: "btn btn-outline-danger btn-sm" %>
      </div>

      <div class="text-center mt-3">
        <%= link_to t('devise.shared.links.back'), :back, class: "text-decoration-none" %>
      </div>
    </div>
  </div>
</div>
